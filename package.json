{
  "name": "toolweave",
  "version": "1.0.0",
  "description": "Convert Swagger/OpenAPI specs into MCP tools for AI agents, deployable via AWS API Gateway",
  "main": "dist/index.js",
  "bin": {
    "toolweave": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
