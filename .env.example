# ToolWeave environment variables
# Copy to .env for local development; on Lambda these are set by the SAM template.

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
# On Lambda, credentials come from the execution role — do NOT set static keys.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Bedrock
# ---------------------------------------------------------------------------
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0

# ---------------------------------------------------------------------------
# DynamoDB — ToolWeave-owned tables (SAM sets these via !Ref at deploy time)
# ---------------------------------------------------------------------------
CATALOG_TABLE_NAME=toolweave-ApiCatalog
META_TABLE_NAME=toolweave-ApiMeta
PROPOSALS_TABLE_NAME=toolweave-Proposals

# ---------------------------------------------------------------------------
# S3 — Swagger/OpenAPI file store (SAM sets this via !Ref at deploy time)
# ---------------------------------------------------------------------------
API_SPECS_BUCKET=toolweave-api-specs-239571291755-us-east-1

# ---------------------------------------------------------------------------
# Shared observatory (propagated from tarun-teamweave-shared stack)
# ---------------------------------------------------------------------------
OBSERVATORY_METRICS_TABLE=tarun-teamweave-shared-OBSERVATORY_METRICS
OBSERVATORY_SECRET_KEY=change-me-in-production   # use a strong random value in prod
OBSERVATORY_BLOCK_THRESHOLD=0.45

# ---------------------------------------------------------------------------
# External services
# ---------------------------------------------------------------------------
DATA_DICTIONARY_URL=https://ft5yitoykshqz73sejd7miatze0syqds.lambda-url.us-east-1.on.aws/

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# DATA_DICTIONARY_CONTEXT=OrdersAPI   # overrides the auto-inferred context from api_title
