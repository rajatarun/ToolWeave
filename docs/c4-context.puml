@startuml C4-Context-ToolWeave
' C4 Level 1 – System Context Diagram
' ToolWeave: NL-to-REST API bridge via MCP

title ToolWeave — C4 Level 1: System Context

top to bottom direction

!include ./assets/C4Context.puml

' ── Actors ───────────────────────────────────────────────────────────────────
Person(developer, "Developer / MCP Client", "Uses an MCP-compatible client\n(e.g. Claude Desktop, custom app)\nto issue natural-language API requests")

Person(api_owner, "API Owner", "Uploads OpenAPI/Swagger specs\nto bootstrap the API catalog")

' ── Internal System ──────────────────────────────────────────────────────────
System(toolweave, "ToolWeave", "FastMCP server that translates\nnatural-language prompts into\nREST API calls with proposal\ngating for write operations")

' ── External Systems ─────────────────────────────────────────────────────────
System_Ext(target_api, "Target REST APIs", "Customer / partner REST services\nthat ToolWeave executes on behalf\nof the caller")

System_Ext(bedrock, "Amazon Bedrock\n(Claude 3 Haiku)", "Foundation model used for\nAI-powered API planning\nand endpoint enrichment")

System_Ext(data_dictionary, "DataDictionary MCP", "Shared MCP Lambda service\nthat provides field-level\nmetadata (format, constraints)")

System_Ext(observatory, "mcp-observatory", "Risk scoring and proposal/commit\ngating library — HMAC token\nmanagement and metrics")

' ── Relationships ────────────────────────────────────────────────────────────
Rel(developer, toolweave, "Calls MCP tools", "MCP over HTTPS")
Rel(api_owner, toolweave, "Uploads OpenAPI spec to S3\nTriggers catalog ingestion", "AWS Console / CLI")
Rel(toolweave, target_api, "Executes REST calls on\nbehalf of developer", "HTTPS / JSON")
Rel(toolweave, bedrock, "AI planning & enrichment", "AWS SDK / Converse API")
Rel(toolweave, data_dictionary, "Fetches field metadata", "HTTP JSON-RPC")
Rel(toolweave, observatory, "Risk scoring, proposal\nand commit gating", "Library (in-process)")

@enduml
