@startuml C4-Container-ToolWeave
' C4 Level 2 – Container Diagram
' ToolWeave: NL-to-REST API bridge via MCP

title ToolWeave — C4 Level 2: Containers

top to bottom direction

!include ./assets/C4Container.puml

' ── External Actors ──────────────────────────────────────────────────────────
Person(developer, "Developer / MCP Client", "Issues natural-language\nAPI requests")
Person(api_owner, "API Owner", "Uploads OpenAPI/Swagger specs")

' ── AWS Boundary ─────────────────────────────────────────────────────────────
System_Boundary(aws, "AWS Account  |  us-east-1") {

    Container(apigw, "API Gateway HTTP API", "AWS API Gateway v2", "HTTPS entry point for MCP\nrequests; routes to ToolWeave\nLambda via AWS_PROXY integration")

    Container(toolweave_fn, "ToolWeave Lambda", "Python 3.12 / FastMCP\n1024 MB / 120 s timeout", "Hosts the MCP server.\nExposes 4 tools: pre_tool,\npost_tool, commit_api_call,\nreload_catalog")

    Container(swagger_fn, "SwaggerProcessor Lambda", "Python 3.12\n512 MB / 300 s timeout", "Triggered by EventBridge on\nS3 object creation. Parses\nOpenAPI specs and enriches\nendpoints via Bedrock. Writes\nresults to DynamoDB.")

    ContainerDb(catalog_table, "ApiCatalog Table", "Amazon DynamoDB\nPK: api_id  SK: operation_id", "Stores normalized endpoint\nentries with AI enrichment hints\n(agent_hint, example_prompts, etc.)")

    ContainerDb(meta_table, "ApiMeta Table", "Amazon DynamoDB\nPK: api_id", "Stores per-API metadata:\ntitle, base_url, context_name,\nendpoint_count, parsed_at")

    ContainerDb(proposals_table, "Proposals Table", "Amazon DynamoDB\nPK: proposal_id  TTL: 3600s", "Persists write proposals across\nLambda invocations for the\npre_tool → commit_api_call flow")

    Container(api_specs_bucket, "API Specs Bucket", "Amazon S3\nVersioning enabled", "Stores OpenAPI/Swagger spec\nfiles (.yaml/.yml/.json)\nuploaded by API owners")

    ContainerQueue(event_rule, "S3 Object Created Rule", "Amazon EventBridge", "Forwards S3 ObjectCreated\nevents to SwaggerProcessor\nLambda (avoids CloudFormation\ncircular dependency)")

}

' ── External Systems ─────────────────────────────────────────────────────────
System_Ext(bedrock, "Amazon Bedrock\n(Claude 3 Haiku)", "Foundation model for API\nplanning (Converse API) and\nspec enrichment (per-endpoint)")

System_Ext(data_dictionary, "DataDictionary MCP Lambda", "Shared service providing\nfield-level metadata (format,\nconstraints, examples)")

System_Ext(target_api, "Target REST APIs", "External services called\nby ToolWeave on behalf of\nthe developer")

System_Ext(metrics_table, "Shared Metrics Table", "Amazon DynamoDB in\nteamweave-shared stack.\nStores tool invocation metrics.")

' ── Relationships ────────────────────────────────────────────────────────────
Rel_D(developer, apigw, "MCP tool calls", "HTTPS / JSON-RPC")
Rel_D(api_owner, api_specs_bucket, "Uploads spec files", "AWS SDK / CLI / Console")

Rel_D(apigw, toolweave_fn, "Proxy all requests", "AWS Lambda Invoke")
Rel_D(api_specs_bucket, event_rule, "ObjectCreated event", "EventBridge notification")
Rel_D(event_rule, swagger_fn, "Triggers on new spec", "Lambda Invoke")

Rel(toolweave_fn, catalog_table, "Reads endpoint catalog\nat cold start / reload", "AWS SDK / DynamoDB")
Rel(toolweave_fn, proposals_table, "Saves / reads proposals", "AWS SDK / DynamoDB")
Rel(toolweave_fn, bedrock, "AI planning: Converse API", "AWS SDK / HTTPS")
Rel(toolweave_fn, data_dictionary, "Field metadata lookup", "HTTP JSON-RPC")
Rel(toolweave_fn, target_api, "Executes REST calls", "httpx / HTTPS")
Rel(toolweave_fn, metrics_table, "Writes invocation metrics", "AWS SDK / DynamoDB")

Rel(swagger_fn, api_specs_bucket, "Fetches spec content", "AWS SDK / S3 GetObject")
Rel(swagger_fn, bedrock, "Endpoint enrichment\n(Converse API, per endpoint)", "AWS SDK / HTTPS")
Rel(swagger_fn, catalog_table, "Batch-writes endpoints", "AWS SDK / DynamoDB")
Rel(swagger_fn, meta_table, "Writes API metadata", "AWS SDK / DynamoDB")

@enduml
